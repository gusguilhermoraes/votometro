{
  "expo": {
    "name": "Votômetro",
    "slug": "votometro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "votometro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gusguilhermoraes.votometro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-foreground.png",
        "backgroundImage": "./assets/images/icon-background.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffcb00",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#2d2d33"
          }
        }
      ],
      [
        "@howincodes/expo-dynamic-app-icon",
        {
          "defaultLight": {
            "ios": "./assets/images/icon.png",
            "android": {
              "foregroundImage": "./assets/images/icon-foreground.png",
              "backgroundImage": "./assets/images/icon-background.png",
              "backgroundColor": "#FFCB00"
            }
          },
          "defaultDark": {
            "ios": "./assets/images/icon-dark.png",
            "android": {
              "foregroundImage": "./assets/images/icon-dark-foreground.png",
              "backgroundImage": "./assets/images/icon-dark-background.png",
              "backgroundColor": "#2D2D33"
            }
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-asset",
      "@react-native-google-signin/google-signin",
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3881aa63-d5e3-472e-93e0-fb7da041e275"
      }
    }
  }
}
